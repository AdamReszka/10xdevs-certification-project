# SprintFlow environment — copy to .env and fill in. NEVER commit real values.
# .env is gitignored; only this placeholder file is tracked.

# --- Supabase (public client config) ---
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# --- Database (server only) ---
# Postgres connection string. NOTE: the Supabase *direct* host
# (db.<ref>.supabase.co) is IPv6-only; from IPv4 networks use the Supavisor
# pooler host (aws-0-<region>.pooler.supabase.com, user postgres.<ref>) for
# drizzle-kit migrate.
DATABASE_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Local Hyperdrive dev connection (used by `wrangler dev`).
CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres

# --- Better Auth (F-01) ---
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=<random-32-byte-base64>
# Base URL Better Auth issues cookies/redirects against.
# Local dev: http://localhost:3000 — deployed Worker uses the BETTER_AUTH_URL var.
BETTER_AUTH_URL=http://localhost:3000
